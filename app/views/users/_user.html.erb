<div id="<%= dom_id user %>">
  <div>
    <strong>Name:</strong>
    <%= user.name %>
  </div>

  <div>
    <strong>Email:</strong>
    <%= user.email %>
  </div>

  <% first_post = user.microposts.first %>
  <% if first_post %>
    </br>
    <strong>First Post:</strong>
    <%= render first_post %> 
    <p>
      <%= link_to "Show this micropost", first_post %>
    </p>
  <% else %>
    <p>This user has no posts yet.</p>
  <% end %>

</div>
